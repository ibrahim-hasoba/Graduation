{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=YOUR_SERVER;Database=YOUR_DB;User Id=YOUR_USER;Password=YOUR_PASSWORD;Encrypt=False;MultipleActiveResultSets=True;"
  },
  "JWTSettings": {
    "securityKey": "your-256-bit-key-at-least-32-chars",
    "validIssuer": "https://yourdomain.com",
    "validAudience": "https://yourdomain.com",
    "expiryInMinutes": 60
  },
  "AppSettings": {
    "BaseUrl": "https://yourdomain.com",
    "FrontendBaseUrl": "https://your-frontend.com"
  },
  "EmailSettings": {
    "SmtpServer": "smtp.gmail.com",
    "SmtpPort": 587,
    "SenderEmail": "your-email@gmail.com",
    "SenderPassword": "your-app-password",
    "SenderName": "Your App"
  },
  "GoogleSettings": {
    "ClientId": "your-google-client-id.apps.googleusercontent.com"
  },
  "PaymobSettings": {
    "ApiKey": "your-paymob-api-key",
    "IntegrationId": "your-integration-id",
    "IframeId": "your-iframe-id",
    "HmacSecret": "your-hmac-secret",
    "BaseUrl": "https://accept.paymob.com/api",
    "IframeBaseUrl": "https://accept.paymob.com/api/acceptance/iframes"
  },
  "ContentModeration": {
    "BadWordsFilePath": "badwords.json"
  },
  "ImageProcessing": {
    "MaxWidth": 1920,
    "MaxHeight": 1080,
    "Quality": 85,
    "ThumbnailWidth": 300,
    "ThumbnailHeight": 300
  }
}
